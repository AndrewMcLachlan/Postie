<Solution>
  <Configurations>
    <BuildType Name="Debug" />
    <BuildType Name="Release" />
    <Platform Name="Any CPU" />
  </Configurations>
  <Folder Name="/.github/workflows/">
    <File Path=".github/workflows/build.yml" />
    <File Path=".github/workflows/release.yml" />
  </Folder>
  <Folder Name="/Solution Items/">
    <File Path=".editorconfig" />
    <File Path=".gitignore" />
    <File Path="AGENTS.md" />
    <File Path="CLAUDE.md" />
    <File Path="Directory.Build.props" />
    <File Path="Directory.Packages.props" />
    <File Path="LICENSE" />
    <File Path="README.md" />
    <File Path="SECURITY.md" />
  </Folder>
  <Folder Name="/src/">
    <File Path="src/Directory.Build.props" />
    <Project Path="src/Postie.Cqrs/Postie.Cqrs.csproj" />
    <Project Path="src/Postie.AspNetCore/Postie.AspNetCore.csproj" />
    <Project Path="src/Postie.Cqrs.AspNetCore/Postie.Cqrs.AspNetCore.csproj" />
    <Project Path="src/Postie.AspNetCore.MediatR/Postie.AspNetCore.MediatR.csproj" />
  </Folder>
  <Folder Name="/tests/">
